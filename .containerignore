# Build-context excludes for deploy/Containerfile. Critically keeps the host
# .venv out of `COPY . .`, which would otherwise clobber the image's synced
# virtualenv (its interpreter path is wrong inside the container) and leave
# Django missing at collectstatic time. Also keeps host-only and derived files
# — local DB, secrets, caches, .git — out of the image.
.venv/
.git/
.gitignore
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.ty_cache/
*.egg-info/
db.sqlite3
db.sqlite3-journal
staticfiles/
.env
deploy/secrets/
tests/
