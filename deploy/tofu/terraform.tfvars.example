# Copy to terraform.tfvars (git-ignored) and fill in the NON-SECRET inputs below.
#
# The secret credentials — hcloud_token, gandi_pat, object_storage_access_key,
# object_storage_secret_key, tailscale_auth_key — do NOT belong here. They live
# encrypted in deploy/secrets/secrets.sops.yaml and are injected as TF_VAR_* by
# `make tofu-plan` / `make tofu-apply` (sops exec-env). Keeping plaintext creds
# out of tfvars is deliberate.

# --- Server (cost-optimised x86) ---
server_name     = "blog"
server_type     = "cpx22"     # the existing box; confirm: hcloud server describe
server_location = "hel1"      # TODO confirm
server_image    = "debian-12" # TODO confirm

# Your laptop's SSH public key (public — fine to commit). For admin over the tailnet.
ssh_authorized_key = "ssh-ed25519 AAAA... you@laptop" # TODO

# --- Object Storage ---
object_storage_endpoint = "https://hel1.your-objectstorage.com" # TODO confirm
object_storage_region   = "hel1"
bucket_name             = "jasonbirchall-blog" # TODO confirm/choose

# --- DNS ---
# Only the apex A/AAAA are managed by tofu (they point at the new box). Mail
# records (Proton MX/SPF/DKIM/DMARC) and www stay in Gandi, unmanaged.
dns_zone = "jasonbirchall.dev"
