# Copy to terraform.tfvars (git-ignored) and fill in. Secrets can instead be
# supplied as TF_VAR_* environment variables — prefer that for the sensitive
# ones in CI/automation.

# --- Credentials ---
hcloud_token              = "REPLACE-ME"
gandi_pat                 = "REPLACE-ME"
object_storage_access_key = "REPLACE-ME"
object_storage_secret_key = "REPLACE-ME"
# tailscale_auth_key      = "tskey-auth-REPLACE-ME"   # supply at apply time once N6.2 exists

# --- Server (confirm against the existing box) ---
server_name     = "blog"
server_type     = "cx22"      # TODO confirm
server_location = "hel1"      # TODO confirm
server_image    = "debian-12" # TODO confirm

# Your laptop's SSH public key (public — fine to commit). For admin over the tailnet.
ssh_authorized_key = "ssh-ed25519 AAAA... you@laptop" # TODO

# --- Object Storage ---
object_storage_endpoint = "https://hel1.your-objectstorage.com" # TODO confirm
object_storage_region   = "hel1"
bucket_name             = "jasonbirchall-blog" # TODO confirm/choose

# --- DNS ---
dns_zone = "jasonbirchall.dev"

# Proton mail records — paste the REAL values from Gandi, and import the existing
# records into state before applying (see README). DO NOT DISTURB.
proton_mx_records   = [] # TODO e.g. ["10 mail.protonmail.ch.", "20 mailsec.protonmail.ch."]
proton_spf_record   = "" # TODO e.g. "v=spf1 include:_spf.protonmail.ch ~all"
proton_dmarc_record = "" # TODO e.g. "v=DMARC1; p=quarantine; rua=mailto:..."
proton_dkim_cnames  = {} # TODO e.g. { "protonmail._domainkey" = "protonmail.domainkey.d...dwx.domains.proton.ch." }
