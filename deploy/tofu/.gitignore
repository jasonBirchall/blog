# Local provider plugins and any local state.
.terraform/
*.tfstate
*.tfstate.*
crash.log

# Real variable values and backend secrets — never commit.
*.tfvars
!*.tfvars.example
backend.hcl

# Transient import file (copied from import.tf.example, deleted after apply).
import.tf

# Commit the provider lock so versions are reproducible.
!.terraform.lock.hcl
