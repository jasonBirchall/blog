# Layout for deploy/secrets/secrets.sops.yaml (the real file is encrypted).
#
# Create and encrypt it:
#   cp deploy/secrets/secrets.sops.yaml.example deploy/secrets/secrets.sops.yaml
#   $EDITOR deploy/secrets/secrets.sops.yaml          # paste real values
#   sops --encrypt --in-place deploy/secrets/secrets.sops.yaml
# Edit later (decrypts in your editor, re-encrypts on save):
#   make secrets-edit
#
# Keys prefixed TF_VAR_ are read by OpenTofu (make tofu-plan / tofu-apply, which
# inject them via `sops exec-env`). The rest become podman secrets / deploy.env on
# the box (N6.3). This file is the ONLY home for these values — do not also put
# them in terraform.tfvars.

# --- OpenTofu (laptop, apply-time) ---

# Hetzner Cloud API token. Console -> project -> Security -> API Tokens ->
# Generate API Token, with Read & Write. Scoped to the one project.
TF_VAR_hcloud_token: REPLACE-ME

# Gandi Personal Access Token. admin.gandi.net -> Personal Access Tokens; scope
# it to "manage domain technical configuration" (LiveDNS) on the blog domain only.
TF_VAR_gandi_pat: REPLACE-ME

# Hetzner Object Storage S3 credentials. Console -> project -> Object Storage ->
# Credentials -> Generate credentials; the secret key is shown ONCE — copy it now.
TF_VAR_object_storage_access_key: REPLACE-ME
TF_VAR_object_storage_secret_key: REPLACE-ME

# Tailscale auth key. login.tailscale.com -> Settings -> Keys -> Generate auth
# key: tagged tag:server, single-use (not reusable), pre-authorized, short expiry.
# cloud-init consumes it to join the tailnet; regenerate one per provision.
TF_VAR_tailscale_auth_key: REPLACE-ME

# --- On the box (N6.3 -> podman secrets) ---

# Django SECRET_KEY. Generate locally — no service needed:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
django_secret_key: REPLACE-ME

# Proton Mail SMTP token (needs a paid plan with SMTP submission). Proton
# Settings -> IMAP/SMTP -> SMTP submission -> generate, for me@jasonbirchall.dev.
# Alertmanager uses it to email alerts via smtp.protonmail.ch:587.
proton_smtp_token: REPLACE-ME

# healthchecks.io ping URL for the DEPLOY heartbeat (N6.6). Create a check, copy
# its https://hc-ping.com/<uuid>. deploy.sh pings it on success, /fail on failure.
healthchecks_ping_url: REPLACE-ME

# healthchecks.io ping URL for the Alertmanager WATCHDOG dead man's switch (N6.7).
# A SEPARATE check (period ~1m, grace ~5m); Alertmanager pings it every minute.
watchdog_healthchecks_url: REPLACE-ME
