{
	# Automatic HTTPS (Let's Encrypt). Uncomment the staging CA until DNS is
	# stable, then re-comment to get real certs.
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
	email me@jasonbirchall.dev

	# Privacy (constitution): never log client IPs or User-Agents.
	log {
		output stdout
		format filter {
			wrap json
			fields {
				request>remote_ip delete
				request>client_ip delete
				request>remote_port delete
				request>headers>User-Agent delete
			}
		}
	}
}

# TODO: confirm the apex/host names.
jasonbirchall.dev, www.jasonbirchall.dev {
	encode zstd gzip

	# Deny sensitive paths (constitution): /.git, /.env, /content, /manage.py.
	@denied path /.git* /.env* /content* /manage.py*
	respond @denied 404

	# Rate limiting for /search (carried from N4.6's DoD). Stock Caddy has no
